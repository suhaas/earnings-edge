{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "UV_SYSTEM_CERTS": "1"
  },
  "model": "claude-opus-4-8",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(uv run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Read(.env)"
    ]
  }
}
