# earnings-edge Environment Variables
# Copy this file to .env and fill in your values
# .env is git-ignored for security
#
# Vars are grouped by whether anything actually reads them today.
# Everything under "PLANNED" is documented intent for unbuilt subsystems — setting it has NO effect.
# If you wire one up, move it into the ACTIVE section in the same change.

# =====================================================================
# ACTIVE — read by code, scripts, Makefile, or docker-compose
# =====================================================================

# ========== Anthropic API ==========
# Get from https://console.anthropic.com/
# Read by: config/settings.py, llm/anthropic_client.py, scripts/check_anthropic_key.py, docker-compose
ANTHROPIC_API_KEY=sk-ant-...

# ========== Composio (delivery) ==========
# Read by: agents/delivery_agent.py, main.py, scripts/check_composio_key.py
COMPOSIO_API_KEY=ak_...your-key-here...
COMPOSIO_USER_ID=jane@example.com

# ========== SEC EDGAR (ingestion) ==========
# SEC requires a descriptive UA string: "Name email".
# Read by: agents/ingestion_agent.py, skills/sec-edgar-8k-retrieval
EDGAR_IDENTITY=Jane Analyst jane@example.com

# ========== EarningsCall (transcripts) ==========
# Blank = AAPL/MSFT only. Does not appear in our source: the `earningscall` library
# reads this from the environment itself (earningscall/api.py). Keep it defined.
EARNINGSCALL_API_KEY=

# ========== Database ==========
# PostgreSQL connection string.
# When set to a postgres:// URL, `run` uses DURABLE PostgresSaver + PostgresStore
# checkpoints (requires the `postgres` container: `docker compose up -d postgres`).
# Leave it COMMENTED OUT for local dev to use a local SQLite file + in-memory store.
# An unreachable Postgres falls back to SQLite with a warning rather than hard-failing.
# Password must match POSTGRES_PASSWORD in docker-compose.yml.
# Read by: main.py (os.environ, NOT via Settings), docker-compose
# DATABASE_URL=postgresql://agentic:dev-password@localhost:5432/earnings_edge

# ========== Vector Database ==========
# NOTE: no retrieval code reads this yet (see PLANNED/RAG below); it is required by
# config/settings.py and consumed by the qdrant service in docker-compose.
VECTORDB_URL=http://localhost:6333

# ========== Observability ==========
# LangSmith for trace visualization. LANGSMITH_TRACING is set by `make trace`.
# NOTE: the LangSmith SDK bundles its own CA store and fails behind a TLS-inspecting
# proxy — keep it off for normal test runs.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false # Flip to true (or use `make trace`) when you want a trace UI for a run.

# OpenTelemetry collector (local stack in docker-compose.yml); set by `make trace`
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Logging level: DEBUG, INFO, WARNING, ERROR (config/settings.py; defaults to INFO)
LOG_LEVEL=INFO


# =====================================================================
# PLANNED — nothing reads these yet. Setting them has NO effect.
# =====================================================================

# ---------- Optional / not currently wired ----------
#OPENAI_API_KEY=sk-...                  # evals/scorers/llm_judge.py does not use OpenAI; we use Claude
#LANGSMITH_PROJECT=earnings-edge-dev
#OTEL_ENABLED=false

# ---------- Agent model routing ----------
# The MODEL REGISTRY in src/agentic_app/config/models.py resolves logical names
# (cheap | balanced | deep) and defaults to `balanced`. It does NOT read env vars,
# and these per-role names do not match the real agents (ingestion, kpi, sentiment,
# synthesis, evaluation, delivery).
#DEFAULT_AGENT_MODEL=balanced
#AGENT_MAX_STEPS=10
#AGENT_TIMEOUT_SECONDS=300

# ---------- RAG ----------
# src/agentic_app/rag/ is a stub (__init__.py only). No ingest/retriever/vectorstore exists.
#VECTORDB_TYPE=qdrant
#VECTORDB_API_KEY=
#EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
#EMBEDDINGS_CACHE_DIR=./data/.embeddings_cache
#CHUNK_SIZE=512
#CHUNK_OVERLAP=50
#RETRIEVAL_TOP_K=5
#RETRIEVAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
#ENABLE_RAG=true

# ---------- Code execution sandbox ----------
# No sandbox/code-exec agent exists in this pipeline.
#CODE_EXEC_BACKEND=subprocess
#CODE_EXEC_TIMEOUT_SECONDS=30
#CODE_EXEC_MEMORY_LIMIT_MB=512
#ENABLE_CODE_EXECUTION=true

# ---------- API server ----------
# api/app.py exposes GET /health only — no /chat, no SSE. Entrypoint is the Typer CLI.
#API_HOST=0.0.0.0
#API_PORT=8000
#API_WORKERS=4
#API_SECRET_KEY=dev-secret-key-change-in-production
#ENABLE_STREAMING=true

# ---------- Data paths ----------
#DATA_DIR=./data
#FIXTURES_DIR=./data/fixtures
#CACHE_DIR=./data/.cache
