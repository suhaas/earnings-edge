# earnings-edge Environment Variables
# Copy this file to .env and fill in your values
# .env is git-ignored for security

# ========== Anthropic API ==========
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...                  # optional (eval judges default to OpenAI; we use Claude)
COMPOSIO_API_KEY=ak_...your-key-here...

EARNINGSCALL_API_KEY=                   # blank = AAPL/MSFT only
EDGAR_IDENTITY=Jane Analyst jane@example.com
COMPOSIO_USER_ID=jane@example.com

# ========== Database ==========
# PostgreSQL connection string.
# When set to a postgres:// URL, `run` uses DURABLE PostgresSaver + PostgresStore
# checkpoints (requires the `postgres` container: `docker compose up -d postgres`).
# Leave it COMMENTED OUT for local dev to use a local SQLite file + in-memory store.
# DATABASE_URL=postgresql://agentic:password@localhost:5432/earnings_edge

# ========== Vector Database ==========
# Option 1: Qdrant (recommended for local dev)
VECTORDB_TYPE=qdrant
VECTORDB_URL=http://localhost:6333
VECTORDB_API_KEY=

# Option 2: pgvector (runs in same Postgres as checkpoints)
# VECTORDB_TYPE=pgvector
# (uses DATABASE_URL above)

# ========== Embeddings ==========
# Model for embeddings (local or API)
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDINGS_CACHE_DIR=./data/.embeddings_cache

# ========== Observability ==========
# LangSmith for trace visualization
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=earnings-edge-dev
LANGSMITH_TRACING=false # When do we switch to ture?

# OpenTelemetry (local stack in docker-compose.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========== Agent Configuration ==========
# Model routing: cheap, balanced, deep (see src/config/models.py)
DEFAULT_AGENT_MODEL=balanced
SUPERVISOR_MODEL=balanced
RESEARCHER_MODEL=balanced
ANALYST_MODEL=deep
CODER_MODEL=balanced
CRITIC_MODEL=balanced

# Agent timeouts (seconds)
AGENT_MAX_STEPS=10
AGENT_TIMEOUT_SECONDS=300

# ========== RAG Configuration ==========
# Chunk size for ingestion (tokens)
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval: max number of documents to retrieve
RETRIEVAL_TOP_K=5
RETRIEVAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ========== Code Execution ==========
# Sandbox environment: docker, subprocess
CODE_EXEC_BACKEND=subprocess
CODE_EXEC_TIMEOUT_SECONDS=30
CODE_EXEC_MEMORY_LIMIT_MB=512

# ========== Application ==========
# API server (if using FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Secret for API authentication (set to random string in production)
API_SECRET_KEY=dev-secret-key-change-in-production

# ========== Data Paths ==========
# Local data directory (git-ignored)
DATA_DIR=./data
FIXTURES_DIR=./data/fixtures
CACHE_DIR=./data/.cache

# ========== Feature Flags ==========
# Enable RAG retrieval (vs. LLM-only)
ENABLE_RAG=true

# Enable code execution
ENABLE_CODE_EXECUTION=true

# Enable streaming responses
ENABLE_STREAMING=true
